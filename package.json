{
  "name": "@aktopia/elements",
  "version": "0.0.0",
  "private": false,
  "type": "module",
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": [
    "./dist/style.css"
  ],
  "scripts": {
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "build:types": "tsc -p tsconfig.build.json",
    "build:js": "vite build",
    "build": "npm run clean && npm run build:js && npm run build:types",
    "pack:dry-run": "npm pack --dry-run",
    "prepare": "npm run build"
  },
  "exports": {
    "./components": {
      "types": "./dist/components.d.ts",
      "import": "./dist/components.js"
    },
    "./utils": {
      "types": "./dist/utils.d.ts",
      "import": "./dist/utils.js"
    },
    "./icons": {
      "types": "./dist/icons.d.ts",
      "import": "./dist/icons.js"
    },
    "./styles": "./dist/style.css"
  },
  "peerDependencies": {
    "react": "^18.3.1 || ^19.0.0",
    "react-dom": "^18.3.1 || ^19.0.0"
  },
  "dependencies": {
    "@headlessui/react": "2.2.7",
    "@heroicons/react": "2.2.0",
    "@radix-ui/react-dropdown-menu": "^2.1.15",
    "@radix-ui/react-tooltip": "^1.2.7",
    "@tiptap/core": "^3.1.0",
    "@tiptap/extension-bold": "^3.1.0",
    "@tiptap/extension-bullet-list": "^3.1.0",
    "@tiptap/extension-document": "^3.1.0",
    "@tiptap/extension-heading": "^3.1.0",
    "@tiptap/extension-history": "^3.1.0",
    "@tiptap/extension-italic": "^3.1.0",
    "@tiptap/extension-list-item": "^3.1.0",
    "@tiptap/extension-ordered-list": "^3.1.0",
    "@tiptap/extension-paragraph": "^3.1.0",
    "@tiptap/extension-placeholder": "^3.1.0",
    "@tiptap/extension-strike": "^3.1.0",
    "@tiptap/extension-text": "^3.1.0",
    "@tiptap/pm": "3.1.0",
    "@tiptap/react": "3.1.0",
    "class-variance-authority": "^0.7.1",
    "dayjs": "^1.11.13",
    "js-base64": "^3.7.8",
    "nanoid": "^5.1.5",
    "react-loading-skeleton": "^3.5.0",
    "tailwind-merge": "^3.3.1"
  },
  "devDependencies": {
    "@headlessui/tailwindcss": "^0.2.2",
    "@tailwindcss/aspect-ratio": "^0.4.2",
    "@tailwindcss/container-queries": "^0.1.1",
    "@tailwindcss/forms": "^0.5.10",
    "@tailwindcss/typography": "^0.5.16",
    "@tailwindcss/vite": "^4.1.11",
    "@types/node": "^24.2.1",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react-swc": "^4.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^4.1.11",
    "tailwindcss-animate": "^1.0.7",
    "tailwindcss-react-aria-components": "^2.0.0",
    "typescript": "^5.9.2",
    "vite": "7.1.2"
  }
}
